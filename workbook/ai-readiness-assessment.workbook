          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-006</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Model Deployments</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Deployed models on Azure OpenAI and AI Services.</span></div>"
            },
