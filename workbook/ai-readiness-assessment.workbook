    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Responsible AI",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RAI-001</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Content Safety</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Dedicated content moderation service.</span></div>"
            },
            "name": "rai001-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| where kind =~ 'ContentSafety'\n| project name, location, resourceGroup, subscriptionId, kind, properties",
              "size": 3,
              "title": "Content Safety Services",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "rai001-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RAI-002</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Content Filtering Enabled</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Checks if Azure OpenAI / AI Services accounts have content safety filtering (RaiMonitor) enabled.</span></div>"
            },
            "name": "rai002-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| where kind in~ ('OpenAI', 'AIServices')\n| extend caps = properties.capabilities\n| mv-expand cap = caps\n| where tostring(cap.name) == 'RaiMonitor'\n| project name, kind, resourceGroup, subscriptionId, contentFilterEnabled = 'Yes'",
              "size": 3,
              "title": "Content Filtering on AI Services",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No Azure OpenAI / AI Services accounts with content filtering found.",
              "noDataMessageStyle": 4
            },
            "name": "rai002-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RAI-003</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Red Teaming Runs</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Manual/API &#x2014; Check for completed red teaming runs and Attack Success Rate (ASR) metrics.</span></div><div style='margin:4px 0 8px 0;padding:8px 12px;background:#fff4ce;border-left:3px solid #ffb900;border-radius:3px;font-size:12px;color:#323130'><strong>&#x26A0; Manual Check Required:</strong> Use AI Foundry portal or API to verify red teaming runs.<br/><code>GET https://{account}.services.ai.azure.com/api/projects/{project}/redteams/runs</code></div>"
            },
            "name": "rai003-header"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RAI-004</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Content Safety Feature Matrix</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Content safety capabilities available per AI Services account.</span></div>"
            },
            "name": "rai004-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.cognitiveservices/accounts'\n| where kind in~ ('OpenAI','AIServices','ContentSafety')\n| extend rules = properties.callRateLimit.rules\n| mv-expand rule = rules\n| extend ruleKey = tostring(rule.key)\n| where ruleKey in (\n    'ContentSafety.TextJailbreak',\n    'ContentSafety.TextShieldPrompt',\n    'ContentSafety.TextProtectedMaterial',\n    'ContentSafety.TextGroundedDetection',\n    'ContentSafety.Text',\n    'ContentSafety.Image',\n    'ContentSafety.RaiPoliciesAPI',\n    'ContentSafety.Provenance.Detect',\n    'ContentSafety.AgentTaskAdherence',\n    'ContentSafety.TextCustomCategories'\n  )\n| extend feature = case(\n    ruleKey == 'ContentSafety.TextJailbreak', 'Jailbreak Detection',\n    ruleKey == 'ContentSafety.TextShieldPrompt', 'Prompt Shield',\n    ruleKey == 'ContentSafety.TextProtectedMaterial', 'Protected Material',\n    ruleKey == 'ContentSafety.TextGroundedDetection', 'Groundedness Detection',\n    ruleKey == 'ContentSafety.Text', 'Text Moderation',\n    ruleKey == 'ContentSafety.Image', 'Image Moderation',\n    ruleKey == 'ContentSafety.RaiPoliciesAPI', 'RAI Policies',\n    ruleKey == 'ContentSafety.Provenance.Detect', 'Content Provenance',\n    ruleKey == 'ContentSafety.AgentTaskAdherence', 'Agent Safety',\n    ruleKey == 'ContentSafety.TextCustomCategories', 'Custom Categories',\n    '')\n| project name, kind, feature, subscriptionId\n| order by name asc, feature asc",
              "size": 3,
              "title": "Content Safety Features per AI Account",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No Azure OpenAI / AI Services accounts with content safety features found.",
              "noDataMessageStyle": 4
            },
            "name": "rai004-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RAI-005</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Deployment Guardrail Assignment</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Microsoft Foundry guardrails (RAI policies) assigned to model deployments.</span></div>"
            },
            "name": "rai005-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.cognitiveservices/accounts/deployments'\n| extend raiPolicy = tostring(properties.raiPolicyName),\n         modelName = tostring(properties.model.name),\n         modelVersion = tostring(properties.model.version)\n| extend guardrailStatus = case(\n    isempty(raiPolicy), 'No Policy',\n    raiPolicy contains 'Default', 'Default',\n    'Custom'\n  )\n| project name, modelName, modelVersion, raiPolicy, guardrailStatus, subscriptionId",
              "size": 3,
              "title": "Deployment Guardrail Assignment",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "guardrailStatus",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Custom",
                          "representation": "success",
                          "text": "Custom"
                        },
                        {
                          "operator": "==",
                          "thresholdValue": "Default",
                          "representation": "warning",
                          "text": "Default"
                        },
                        {
                          "operator": "Default",
                          "representation": "error",
                          "text": "No Policy"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No model deployments found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "rai005-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RAI-006</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Guardrail Policy Details</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Manual/API &#x2014; List all RAI policies (guardrails) and their controls on a Foundry resource.</span></div><div style='margin:4px 0 8px 0;padding:8px 12px;background:#fff4ce;border-left:3px solid #ffb900;border-radius:3px;font-size:12px;color:#323130'><strong>&#x26A0; Manual Check Required:</strong> Use the Azure REST API to list guardrail policies and review controls (risks, severity levels, intervention points).<br/><code>GET https://management.azure.com/subscriptions/{sub}/resourceGroups/{rg}/providers/Microsoft.CognitiveServices/accounts/{account}/raiPolicies?api-version=2024-10-01</code></div>"
            },
            "name": "rai006-header"
          }
        ]
      },
      "name": "responsible-ai-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Security & Compliance",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-001</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Managed Identities</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Service-to-service authentication without credentials.</span></div>"
            },
            "name": "sec001-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in (\n    'microsoft.cognitiveservices/accounts',\n    'microsoft.machinelearningservices/workspaces',\n    'microsoft.search/searchservices'\n  )\n| extend hasManagedIdentity = isnotnull(identity)\n| summarize Total=count(), WithManagedIdentity=countif(hasManagedIdentity == true) by type",
              "size": 3,
              "title": "Managed Identity Adoption",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "WithManagedIdentity",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "greenRed"
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "sec001-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-002</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Key Vault</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Centralized secret management with soft delete and RBAC.</span></div>"
            },
            "name": "sec002-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.keyvault/vaults'\n| extend softDelete = properties.enableSoftDelete,\n         purgeProtection = properties.enablePurgeProtection,\n         rbac = properties.enableRbacAuthorization\n| project name, location, subscriptionId, softDelete, purgeProtection, rbac",
              "size": 3,
              "title": "Key Vault Security",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "softDelete",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success"
                        },
                        {
                          "operator": "Default",
                          "representation": "error"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "purgeProtection",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success"
                        },
                        {
                          "operator": "Default",
                          "representation": "error"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "rbac",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success"
                        },
                        {
                          "operator": "Default",
                          "representation": "error"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "sec002-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-003</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Private Networking &amp; PE State</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Network isolation with private endpoints.</span></div>"
            },
            "name": "sec003-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in (\n    'microsoft.cognitiveservices/accounts',\n    'microsoft.machinelearningservices/workspaces',\n    'microsoft.search/searchservices',\n    'microsoft.storage/storageaccounts',\n    'microsoft.cache/redis'\n  )\n| extend publicAccess = tostring(properties.publicNetworkAccess),\n         peCount = array_length(properties.privateEndpointConnections),\n         peState = tostring(properties.privateEndpointConnections[0].properties.privateLinkServiceConnectionState.status)\n| project name, type, publicAccess, peCount, peState, location, subscriptionId",
              "size": 3,
              "title": "Private Networking Status",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "publicAccess",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Disabled",
                          "representation": "success",
                          "text": "Disabled"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "{0}"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "peState",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Approved",
                          "representation": "success",
                          "text": "Approved"
                        },
                        {
                          "operator": "Default",
                          "representation": "2",
                          "text": "{0}"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "sec003-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-004</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Defender for Cloud</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Security posture and threat protection plans.</span></div>"
            },
            "name": "sec004-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "securityresources\n| where type == 'microsoft.security/pricings'\n| where name in ('CloudPosture', 'Containers', 'VirtualMachines', 'StorageAccounts', 'Api')\n| project name, tier=tostring(properties.pricingTier)",
              "size": 3,
              "title": "Defender Plans Status",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "tier",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Standard",
                          "representation": "success",
                          "text": "Standard"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "Free"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "sec004-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-005</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Defender for AI Services</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Threat protection for AI workloads.</span></div>"
            },
            "name": "sec005-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "securityresources\n| where type == 'microsoft.security/pricings'\n| where name == 'AI'\n| project name, tier=tostring(properties.pricingTier)",
              "size": 3,
              "title": "Defender for AI Services",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "tier",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "Standard",
                          "representation": "success",
                          "text": "Standard"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "Free"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "sec005-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-006</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Model API Authentication</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Identity-based auth for AI services.</span></div>"
            },
            "name": "sec006-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.cognitiveservices/accounts'\n| where kind in ('OpenAI', 'AIServices')\n| extend disableLocalAuth = properties.disableLocalAuth,\n         publicAccess = properties.publicNetworkAccess\n| summarize Total=count(), LocalAuthDisabled=countif(disableLocalAuth == true), PublicDisabled=countif(publicAccess == 'Disabled')",
              "size": 3,
              "title": "AI Services Auth Summary",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "tiles",
              "tileSettings": {
                "showBorder": true
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "sec006-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>SEC-007</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>APIM as AI Gateway</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>API Management for centralized AI API access control.</span></div>"
            },
            "name": "sec007-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.apimanagement/service'\n| extend sku = tostring(sku.name),\n         identity = identity.type\n| project name, sku, identity, location, subscriptionId",
              "size": 3,
              "title": "API Management Instances",
              "queryType": 1,
