      "name": "data-management-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Retrieval & Context Enablement",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RCE-001</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>AI Search</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Azure AI Search &#x2014; Semantic and vector search capabilities.</span></div>"
            },
            "name": "rce001-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.search/searchservices'\n| extend sku = tostring(sku.name),\n         semanticSearch = tostring(properties.semanticSearch),\n         replicaCount = toint(properties.replicaCount),\n         partitionCount = toint(properties.partitionCount),\n         publicAccess = properties.publicNetworkAccess,\n         status = tostring(properties.status),\n         provisioningState = tostring(properties.provisioningState),\n         vectorCapable = tostring(sku.name) in ('standard','standard2','standard3','storage_optimized_l1','storage_optimized_l2')\n| project name, sku, semanticSearch, vectorCapable, replicaCount, partitionCount, publicAccess, status, provisioningState, subscriptionId",
              "size": 3,
              "title": "AI Search Services",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "vectorCapable",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Yes"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "No"
                        }
                      ]
                    }
                  },
                  {
                    "columnMatch": "status",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "running",
                          "representation": "success",
                          "text": "Running"
                        },
                        {
                          "operator": "Default",
                          "representation": "error",
                          "text": "{0}"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "rce001-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RCE-002</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Redis Cache</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Azure Cache for Redis &#x2014; Semantic caching and response caching.</span></div>"
            },
            "name": "rce002-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.cache/redis' or type == 'microsoft.cache/redisenterprise'\n| extend sku = tostring(sku.name),\n         capacity = toint(sku.capacity)\n| project name, sku, capacity, location, subscriptionId",
              "size": 3,
              "title": "Redis Cache Instances",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "rce002-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RCE-003</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Cosmos DB / PostgreSQL</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Vector-capable databases for RAG patterns.</span></div>"
            },
            "name": "rce003-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.documentdb/databaseaccounts'\n    or (type == 'microsoft.dbforpostgresql/flexibleservers')\n| extend dbKind = case(\n    type == 'microsoft.documentdb/databaseaccounts', 'Cosmos DB',\n    type == 'microsoft.dbforpostgresql/flexibleservers', 'PostgreSQL Flexible',\n    'Other'\n  )\n| extend vectorSearch = properties.capabilities has 'EnableNoSQLVectorSearch'\n| project name, dbKind, vectorSearch, location, subscriptionId",
              "size": 3,
              "title": "Cosmos DB / PostgreSQL",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "vectorSearch",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Enabled"
                        },
                        {
                          "operator": "Default",
                          "representation": "2",
                          "text": "Not Enabled"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "rce003-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RCE-004</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Vector Stores</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>All vector-capable stores: AI Search, Cosmos DB, PostgreSQL.</span></div>"
            },
            "name": "rce004-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.search/searchservices'\n    or (type == 'microsoft.documentdb/databaseaccounts' and properties.capabilities has 'EnableNoSQLVectorSearch')\n    or (type == 'microsoft.dbforpostgresql/flexibleservers')\n| extend storeType = case(\n    type == 'microsoft.search/searchservices', 'AI Search',\n    type == 'microsoft.documentdb/databaseaccounts', 'Cosmos DB (vector)',\n    type == 'microsoft.dbforpostgresql/flexibleservers', 'PostgreSQL (pgvector)',\n    'Other'\n  )\n| project name, storeType, location, subscriptionId",
              "size": 3,
              "title": "Vector Stores",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "rce004-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>RCE-005</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Document Intelligence</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Azure AI Document Intelligence &#x2014; OCR and document processing.</span></div>"
            },
            "name": "rce005-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.cognitiveservices/accounts'\n| where kind == 'FormRecognizer' or kind == 'DocumentIntelligence'\n| extend sku = tostring(sku.name),\n         publicAccess = properties.publicNetworkAccess\n| project name, kind, sku, publicAccess, location, subscriptionId",
              "size": 3,
              "title": "Document Intelligence",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
