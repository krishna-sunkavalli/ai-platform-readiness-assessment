          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-005</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Online Endpoints</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Real-time model serving endpoints.</span></div>"
            },
            "name": "mdl005-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.machinelearningservices/workspaces/onlineendpoints'\n| extend authMode = tostring(properties.authMode),\n         provisioningState = tostring(properties.provisioningState)\n| project name, location, authMode, provisioningState, subscriptionId",
              "size": 3,
              "title": "Online Endpoints",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
