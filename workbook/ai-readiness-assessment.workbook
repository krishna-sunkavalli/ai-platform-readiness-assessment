{
  "version": "Notebook/1.0",
  "items": [
    {
      "type": 1,
      "content": {
        "json": "<div style='padding:16px 20px;background:#eff6fc;border-left:3px solid #0078d4;border-radius:6px;margin-bottom:8px'><h2 style='margin:0 0 4px 0;color:#0078d4;font-size:18px'>AI Platform Readiness Assessment</h2><p style='margin:0;font-size:13px;color:#605e5c'>Evaluates your Azure environment across six readiness pillars. Select subscription(s) to run the assessment.</p></div>"
      },
      "name": "header"
    },
    {
      "type": 9,
      "content": {
        "version": "KqlParameterItem/1.0",
        "parameters": [
          {
            "id": "subscription",
            "version": "KqlParameterItem/1.0",
            "name": "Subscription",
            "type": 6,
            "isRequired": true,
            "multiSelect": true,
            "quote": "'",
            "delimiter": ",",
            "typeSettings": {
              "additionalResourceOptions": [
                "value::all"
              ],
              "includeAll": true,
              "showDefault": false
            },
            "defaultValue": "value::all"
          },
          {
            "id": "pillar-bars-param",
            "version": "KqlParameterItem/1.0",
            "name": "PillarBarsHtml",
            "type": 1,
            "query": "resources\n| summarize purview=countif(type=='microsoft.purview/accounts'), databricks=countif(type=='microsoft.databricks/workspaces'), adf=countif(type=='microsoft.datafactory/factories'), adls=countif(type=='microsoft.storage/storageaccounts' and tobool(properties.isHnsEnabled)==true), aisearch=countif(type=='microsoft.search/searchservices'), redis=countif(type in ('microsoft.cache/redis','microsoft.cache/redisenterprise')), cosmos=countif(type=='microsoft.documentdb/databaseaccounts'), docint=countif(type=='microsoft.cognitiveservices/accounts' and kind in ('FormRecognizer','DocumentIntelligence')), aoai=countif(type=='microsoft.cognitiveservices/accounts' and kind in ('OpenAI','AIServices')), aml=countif(type=='microsoft.machinelearningservices/workspaces'), foundry=countif(type=~'microsoft.cognitiveservices/accounts/projects'), contentsafety=countif(type=='microsoft.cognitiveservices/accounts' and kind=~'ContentSafety'), keyvault=countif(type=='microsoft.keyvault/vaults'), managed_id=countif(type in ('microsoft.cognitiveservices/accounts','microsoft.machinelearningservices/workspaces','microsoft.search/searchservices') and isnotnull(identity)), apim=countif(type=='microsoft.apimanagement/service'), appinsights=countif(type=='microsoft.insights/components')\n| extend Pillars = pack_array(\n    strcat('Data Management & Governance|1|8|', tostring(iff(purview>0,3,0)+iff(databricks>0,2,0)+iff(adf>0,1,0)+iff(adls>0,2,0))),\n    strcat('Retrieval & Context Enablement|2|5|', tostring(iff(aisearch>0,2,0)+iff(redis>0,1,0)+iff(cosmos>0,1,0)+iff(docint>0,1,0))),\n    strcat('Model Management|3|8|', tostring(iff(aoai>0,3,0)+iff(aml>0,2,0)+iff(foundry>0,3,0))),\n    strcat('Responsible AI|4|3|', tostring(iff(contentsafety>0,3,0))),\n    strcat('Security & Compliance|5|7|', tostring(iff(keyvault>0,2,0)+iff(managed_id>0,3,0)+iff(apim>0,2,0))),\n    strcat('Monitoring & Operations|6|5|', tostring(iff(appinsights>0,3,0)+iff(managed_id>0,2,0))))\n| mv-expand Pillars to typeof(string)\n| extend parts = split(Pillars, '|')\n| extend Pillar=tostring(parts[0]), SortOrder=toint(parts[1]), MaxScore=toint(parts[2]), WeightedScore=toint(parts[3])\n| extend ScorePercent=toint(round(100.0*WeightedScore/MaxScore, 0))\n| order by SortOrder asc\n| extend BarColor=iff(ScorePercent>=75, '#00b294', iff(ScorePercent>=40, '#ff8c00', '#e81123'))\n| extend row=strcat('<div style=\"display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid #f3f2f1\"><div style=\"min-width:240px;font-size:13px;color:#0078d4;font-weight:600\">', Pillar, '</div><div style=\"flex:1;height:12px;background:#edebe9;border-radius:2px;overflow:hidden;min-width:120px\"><div style=\"height:100%;width:', tostring(ScorePercent), '%;background:', BarColor, ';border-radius:2px\"></div></div><span style=\"min-width:44px;text-align:right;font-size:13px;font-weight:600;color:#323130\">', tostring(ScorePercent), '%</span></div>')\n| summarize allrows=strcat_array(make_list(row), '')\n| project allrows",
            "isHiddenWhenLocked": true,
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscription}"
            ]
          },
          {
            "id": "score-card-param",
            "version": "KqlParameterItem/1.0",
            "name": "ScoreCardHtml",
            "type": 1,
            "query": "resources\n| summarize purview=countif(type=='microsoft.purview/accounts'), databricks=countif(type=='microsoft.databricks/workspaces'), adf=countif(type=='microsoft.datafactory/factories'), adls=countif(type=='microsoft.storage/storageaccounts' and tobool(properties.isHnsEnabled)==true), aisearch=countif(type=='microsoft.search/searchservices'), redis=countif(type in ('microsoft.cache/redis','microsoft.cache/redisenterprise')), cosmos=countif(type=='microsoft.documentdb/databaseaccounts'), docint=countif(type=='microsoft.cognitiveservices/accounts' and kind in ('FormRecognizer','DocumentIntelligence')), aoai=countif(type=='microsoft.cognitiveservices/accounts' and kind in ('OpenAI','AIServices')), aml=countif(type=='microsoft.machinelearningservices/workspaces'), foundry=countif(type=~'microsoft.cognitiveservices/accounts/projects'), contentsafety=countif(type=='microsoft.cognitiveservices/accounts' and kind=~'ContentSafety'), keyvault=countif(type=='microsoft.keyvault/vaults'), managed_id=countif(type in ('microsoft.cognitiveservices/accounts','microsoft.machinelearningservices/workspaces','microsoft.search/searchservices') and isnotnull(identity)), apim=countif(type=='microsoft.apimanagement/service'), appinsights=countif(type=='microsoft.insights/components')\n| extend TotalWeighted = iff(purview>0,3,0)+iff(databricks>0,2,0)+iff(adf>0,1,0)+iff(adls>0,2,0)+iff(aisearch>0,2,0)+iff(redis>0,1,0)+iff(cosmos>0,1,0)+iff(docint>0,1,0)+iff(aoai>0,3,0)+iff(aml>0,2,0)+iff(foundry>0,3,0)+iff(contentsafety>0,3,0)+iff(keyvault>0,2,0)+iff(managed_id>0,3,0)+iff(apim>0,2,0)+iff(appinsights>0,3,0)\n| extend MaxTotal = 36\n| extend S = toint(round(100.0 * TotalWeighted / MaxTotal, 0))\n| extend ScoreColor=iff(S>=80, '#107c10', iff(S>=50, '#d69900', '#d13438'))\n| extend RingPct = S * 2.51327\n| extend html=strcat('<div style=\"display:flex;flex-direction:column;align-items:center;justify-content:center;padding:12px 8px\"><div style=\"font-size:13px;font-weight:600;color:#605e5c;text-transform:uppercase;letter-spacing:1px;margin-bottom:12px\">AI Readiness Score</div><div style=\"position:relative;width:160px;height:160px\"><svg viewBox=\"0 0 100 100\" style=\"transform:rotate(-90deg)\"><circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#edebe9\" stroke-width=\"8\"/><circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"', ScoreColor, '\" stroke-width=\"8\" stroke-dasharray=\"', tostring(RingPct), ' 251.327\" stroke-linecap=\"round\"/></svg><div style=\"position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center\"><div style=\"font-size:38px;font-weight:700;color:', ScoreColor, ';line-height:1\">', tostring(S), '%</div></div></div></div>')\n| project html",
            "isHiddenWhenLocked": true,
            "queryType": 1,
            "resourceType": "microsoft.resourcegraph/resources",
            "crossComponentResources": [
              "{Subscription}"
            ]
          }
        ],
        "style": "pills"
      },
      "name": "parameters"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Assessment Summary",
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style=\"border:1px solid #edebe9;border-radius:8px;background:#fff;box-shadow:0 2px 8px rgba(0,0,0,0.08);height:100%\">{ScoreCardHtml}</div>"
            },
            "customWidth": "25",
            "name": "overall-score-tile"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style=\"padding:0 4px\">\r\n\r\n**Readiness by Pillar**\r\n\r\n{PillarBarsHtml}\r\n</div>"
            },
            "customWidth": "75",
            "name": "pillar-grid"
          }
        ]
      },
      "name": "summary-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "AI Resource Landscape",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:8px 0;font-size:12px;color:#605e5c'>Geographic distribution of AI-related resources across selected subscriptions. This section is informational and does not affect the readiness score.</div>"
            },
            "name": "landscape-description"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in~ (\n    'microsoft.cognitiveservices/accounts',\n    'microsoft.cognitiveservices/accounts/deployments',\n    'microsoft.cognitiveservices/accounts/projects',\n    'microsoft.machinelearningservices/workspaces',\n    'microsoft.search/searchservices',\n    'microsoft.cache/redis',\n    'microsoft.cache/redisenterprise',\n    'microsoft.documentdb/databaseaccounts',\n    'microsoft.purview/accounts',\n    'microsoft.databricks/workspaces',\n    'microsoft.datafactory/factories',\n    'microsoft.apimanagement/service',\n    'microsoft.insights/components'\n  )\n| summarize resourceCount = count() by location\n| order by resourceCount desc",
              "size": 3,
              "title": "AI Resources by Region",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "map",
              "mapSettings": {
                "locInfo": "AzureLoc",
                "locInfoColumn": "location",
                "sizeSettings": "resourceCount",
                "sizeAggregation": "Sum",
                "legendMetric": "resourceCount",
                "legendAggregation": "Sum",
                "itemColorSettings": {
                  "nodeColorField": "resourceCount",
                  "colorAggregation": "Sum",
                  "type": "heatmap",
                  "heatmapPalette": "greenRed"
                }
              },
              "noDataMessage": "No AI resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "landscape-map"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in~ (\n    'microsoft.cognitiveservices/accounts',\n    'microsoft.cognitiveservices/accounts/deployments',\n    'microsoft.cognitiveservices/accounts/projects',\n    'microsoft.machinelearningservices/workspaces',\n    'microsoft.search/searchservices',\n    'microsoft.cache/redis',\n    'microsoft.cache/redisenterprise',\n    'microsoft.documentdb/databaseaccounts',\n    'microsoft.purview/accounts',\n    'microsoft.databricks/workspaces',\n    'microsoft.datafactory/factories',\n    'microsoft.apimanagement/service',\n    'microsoft.insights/components'\n  )\n| extend serviceCategory = case(\n    type =~ 'microsoft.cognitiveservices/accounts' and kind in~ ('OpenAI','AIServices'), 'Azure OpenAI / AI Services',\n    type =~ 'microsoft.cognitiveservices/accounts' and kind =~ 'ContentSafety', 'Content Safety',\n    type =~ 'microsoft.cognitiveservices/accounts', 'Cognitive Services',\n    type =~ 'microsoft.cognitiveservices/accounts/deployments', 'Model Deployment',\n    type =~ 'microsoft.cognitiveservices/accounts/projects', 'AI Foundry Project',\n    type =~ 'microsoft.machinelearningservices/workspaces', 'ML Workspace',\n    type =~ 'microsoft.search/searchservices', 'AI Search',\n    type in~ ('microsoft.cache/redis','microsoft.cache/redisenterprise'), 'Redis Cache',\n    type =~ 'microsoft.documentdb/databaseaccounts', 'Cosmos DB',\n    type =~ 'microsoft.purview/accounts', 'Purview',\n    type =~ 'microsoft.databricks/workspaces', 'Databricks',\n    type =~ 'microsoft.datafactory/factories', 'Data Factory',\n    type =~ 'microsoft.apimanagement/service', 'API Management',\n    type =~ 'microsoft.insights/components', 'App Insights',\n    'Other'\n  )\n| summarize resourceCount = count() by location, serviceCategory\n| order by location asc, serviceCategory asc",
              "size": 3,
              "title": "AI Resources by Region & Service",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "resourceCount",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "blue"
                    }
                  }
                ]
              },
              "noDataMessage": "No AI resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "landscape-table"
          }
        ]
      },
      "name": "landscape-group"
    },
    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Data Management & Governance",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-001</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Purview Accounts</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Microsoft Purview &#x2014; Unified data governance platform.</span></div>"
            },
            "name": "dmg001-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.purview/accounts'\n| project name, location, subscriptionId, properties",
              "size": 3,
              "title": "Purview Accounts",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "name",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "showIcon": true
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg001-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-002</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Purview Scan Rulesets</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Validate scan rulesets are configured for data discovery.</span></div>"
            },
            "name": "dmg002-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.purview/accounts'\n| where isnotnull(properties.scanRulesets)\n| project name, location, subscriptionId, scanRulesets=properties.scanRulesets",
              "size": 3,
              "title": "Purview Scan Rulesets",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg002-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-003</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Data Classification Rules</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Check for cloud connector configurations enabling data classification.</span></div>"
            },
            "name": "dmg003-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.purview/accounts'\n| where isnotnull(properties.cloudConnectors)\n| project name, location, subscriptionId, properties",
              "size": 3,
              "title": "Data Classification Rules",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg003-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-004</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Data Lineage Enablement</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Verify lineage endpoints are configured for tracking data flow.</span></div>"
            },
            "name": "dmg004-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.purview/accounts'\n| extend lineageEndpoint = tostring(properties.endpoints.lineage)\n| where isnotnull(lineageEndpoint)\n| project name, lineageEndpoint, location, subscriptionId",
              "size": 3,
              "title": "Data Lineage Enablement",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg004-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-005</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Unity Catalog</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Azure Databricks workspaces for unified analytics governance.</span></div>"
            },
            "name": "dmg005-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.databricks/workspaces'\n| extend unityCatalog = properties.parameters.enableNoPublicIp\n| project name, location, subscriptionId, properties",
              "size": 3,
              "title": "Databricks Workspaces (Unity Catalog)",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "name",
                    "formatter": 13,
                    "formatOptions": {
                      "linkTarget": "Resource",
                      "showIcon": true
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg005-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-006</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>ADF ETL Coverage</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Azure Data Factory &#x2014; Data pipelines with Git integration.</span></div>"
            },
            "name": "dmg006-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.datafactory/factories'\n| extend gitConfigured = isnotnull(properties.repoConfiguration.repositoryName),\n         globalParams = array_length(bag_keys(properties.globalParameters))\n| project name, location, subscriptionId, gitConfigured, globalParams",
              "size": 3,
              "title": "Data Factories",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "gitConfigured",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Yes"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "No"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg006-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-007</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Lakehouse Presence</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>ADLS Gen2, Databricks, or Microsoft Fabric for enterprise data lake.</span></div>"
            },
            "name": "dmg007-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in (\n    'microsoft.storage/storageaccounts',\n    'microsoft.databricks/workspaces',\n    'microsoft.fabric/capacities'\n  )\n| extend layer = case(\n    type == 'microsoft.storage/storageaccounts' and properties.isHnsEnabled == true, 'ADLS Gen2',\n    type == 'microsoft.databricks/workspaces', 'Databricks',\n    type == 'microsoft.fabric/capacities', 'Microsoft Fabric',\n    'Other'\n  )\n| where layer != 'Other'\n| project name, layer, location, subscriptionId",
              "size": 3,
              "title": "Lakehouse Presence",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "dmg007-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>DMG-008</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Retention &amp; Lifecycle Policies</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>ADLS Gen2 lifecycle management policies.</span></div>"
            },
            "name": "dmg008-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.storage/storageaccounts'\n| where kind == 'StorageV2' and properties.isHnsEnabled == true\n| extend lifecyclePolicy = isnotnull(properties.managementPolicies)\n| project name, location, subscriptionId, lifecyclePolicy",
              "size": 3,
              "title": "ADLS Gen2 Lifecycle Policies",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
