          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-007</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Fine-Tuned Models</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Custom fine-tuned model deployments.</span></div>"
            },
            "name": "mdl007-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.cognitiveservices/accounts/deployments'\n| where properties.model.source contains 'fine-tun'\n    or properties.model.format =~ 'custom'\n| extend modelName = tostring(properties.model.name),\n         modelVersion = tostring(properties.model.version)\n| project name, modelName, modelVersion, location, subscriptionId",
              "size": 3,
