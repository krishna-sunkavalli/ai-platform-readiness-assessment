    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Model Management",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-001</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Azure OpenAI / AI Services</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Core model hosting services.</span></div>"
            },
            "name": "mdl001-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.cognitiveservices/accounts'\n| where kind in ('OpenAI', 'AIServices')\n| extend sku = tostring(sku.name),\n         publicAccess = properties.publicNetworkAccess,\n         disableLocalAuth = properties.disableLocalAuth,\n         privateEndpoints = array_length(properties.privateEndpointConnections)\n| project name, kind, sku, publicAccess, disableLocalAuth, privateEndpoints, location, subscriptionId",
              "size": 3,
              "title": "Azure OpenAI / AI Services",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "disableLocalAuth",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Disabled"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "Enabled"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mdl001-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-002</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>ML Workspaces</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Azure Machine Learning workspaces with MLflow tracking.</span><span style='font-size:11px;color:#a19f9d;margin-left:8px;font-style:italic'>(Optional — now covered by Foundry)</span></div>"
            },
            "name": "mdl002-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.machinelearningservices/workspaces'\n| extend mlflow = properties.mlFlowTrackingUri,\n         publicAccess = properties.publicNetworkAccess,\n         hbiWorkspace = properties.hbiWorkspace,\n         appInsights = isnotnull(properties.applicationInsights),\n         identity = identity.type\n| project name, mlflow, publicAccess, hbiWorkspace, appInsights, identity, subscriptionId",
              "size": 3,
              "title": "Azure ML Workspaces",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "appInsights",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Configured"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "Not Set"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mdl002-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-003</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>GPU Compute</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>GPU resources for model training and inference.</span><span style='font-size:11px;color:#a19f9d;margin-left:8px;font-style:italic'>(Optional — now covered by Foundry)</span></div>"
            },
            "name": "mdl003-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in ('microsoft.machinelearningservices/workspaces/computes', 'microsoft.compute/virtualmachines')\n| extend vmSize = coalesce(properties.properties.vmSize, tostring(properties.hardwareProfile.vmSize))\n| where vmSize contains 'NC' or vmSize contains 'ND' or vmSize contains 'NV'\n| summarize count() by vmSize",
              "size": 3,
              "title": "GPU Resources",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "piechart",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mdl003-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MDL-004</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>AI Foundry Projects</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>AI Foundry projects for organizing models, data, and agents.</span></div>"
            },
            "name": "mdl004-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type =~ 'microsoft.cognitiveservices/accounts/projects'\n| extend hasIdentity = isnotnull(identity.principalId),\n         endpoint = tostring(properties.endpoints)\n| project name, location, hasIdentity, endpoint, subscriptionId",
              "size": 3,
