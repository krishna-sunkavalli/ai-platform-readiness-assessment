    {
      "type": 12,
      "content": {
        "version": "NotebookGroup/1.0",
        "groupType": "editable",
        "title": "Monitoring & Operations",
        "expandable": true,
        "expanded": false,
        "items": [
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MON-001</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Application Insights</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>APM for AI applications.</span></div>"
            },
            "name": "mon001-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.insights/components'\n| project name, applicationId=properties.ApplicationId, ingestionMode=properties.IngestionMode, subscriptionId",
              "size": 3,
              "title": "Application Insights Instances",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mon001-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MON-002</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>AI Services Diagnostics</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Diagnostic settings coverage for AI resources.</span></div>"
            },
            "name": "mon002-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in (\n    'microsoft.cognitiveservices/accounts',\n    'microsoft.machinelearningservices/workspaces'\n  )\n| project resourceName=name, resourceId=id, kind, subscriptionId\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.insights/diagnosticsettings'\n    | extend targetId = tostring(split(id, '/providers/microsoft.insights')[0])\n    | project targetId, diagName=name, workspaceId=properties.workspaceId\n) on $left.resourceId == $right.targetId\n| summarize Total=count(), WithDiagnostics=countif(isnotnull(diagName)) by kind",
              "size": 3,
              "title": "AI Services Diagnostics Coverage",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "WithDiagnostics",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "greenRed"
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mon002-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MON-003</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Metric Alert Rules</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Alert rules targeting Cognitive Services.</span></div>"
            },
            "name": "mon003-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type == 'microsoft.insights/metricalerts'\n| where properties.scopes has 'microsoft.cognitiveservices'\n| extend severity = toint(properties.severity),\n         enabled = tobool(properties.enabled)\n| project name, severity, enabled, location, subscriptionId",
              "size": 3,
              "title": "Metric Alert Rules on Cognitive Services",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "enabled",
                    "formatter": 18,
                    "formatOptions": {
                      "thresholdsOptions": "icons",
                      "thresholdsGrid": [
                        {
                          "operator": "==",
                          "thresholdValue": "true",
                          "representation": "success",
                          "text": "Enabled"
                        },
                        {
                          "operator": "Default",
                          "representation": "warning",
                          "text": "Disabled"
                        }
                      ]
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mon003-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MON-004</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Log Analytics Workspace Coverage</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Central logging for AI resources.</span></div>"
            },
            "name": "mon004-header"
          },
          {
            "type": 3,
            "content": {
              "version": "KqlItem/1.0",
              "query": "resources\n| where type in (\n    'microsoft.cognitiveservices/accounts',\n    'microsoft.machinelearningservices/workspaces',\n    'microsoft.search/searchservices'\n  )\n| project resourceId=id, resourceName=name, type, subscriptionId\n| join kind=leftouter (\n    resources\n    | where type == 'microsoft.insights/diagnosticsettings'\n    | extend targetId = tostring(split(id, '/providers/microsoft.insights')[0])\n    | project targetId, workspaceId=tostring(properties.workspaceId)\n) on $left.resourceId == $right.targetId\n| extend hasWorkspace = isnotnull(workspaceId)\n| summarize Total=count(), RoutingToWorkspace=countif(hasWorkspace == true) by type",
              "size": 3,
              "title": "Log Analytics Workspace Coverage",
              "queryType": 1,
              "resourceType": "microsoft.resourcegraph/resources",
              "crossComponentResources": [
                "{Subscription}"
              ],
              "visualization": "table",
              "gridSettings": {
                "formatters": [
                  {
                    "columnMatch": "RoutingToWorkspace",
                    "formatter": 8,
                    "formatOptions": {
                      "palette": "greenRed"
                    }
                  }
                ]
              },
              "noDataMessage": "No resources found in the selected subscription(s).",
              "noDataMessageStyle": 4
            },
            "name": "mon004-query"
          },
          {
            "type": 1,
            "content": {
              "json": "<div style='margin:16px 0 4px 0;border-bottom:1px solid #edebe9;padding-bottom:4px'><span style='font-size:11px;font-weight:600;color:#0078d4;text-transform:uppercase;letter-spacing:.5px'>MON-005</span>&nbsp;&nbsp;<span style='font-size:14px;font-weight:600;color:#323130'>Quality Evaluators</span><span style='font-size:12px;color:#605e5c;margin-left:8px'>Manual/API &#x2014; Check AI Foundry for groundedness, relevance, coherence, fluency evaluators.</span></div><div style='margin:4px 0 8px 0;padding:8px 12px;background:#fff4ce;border-left:3px solid #ffb900;border-radius:3px;font-size:12px;color:#323130'><strong>&#x26A0; Manual Check Required:</strong> Use AI Foundry portal or API to verify quality evaluators are configured.<br/><code>GET https://{account}.services.ai.azure.com/api/projects/{project}/evaluations</code></div>"
            },
            "name": "mon005-header"
          }
        ]
      },
      "name": "monitoring-group"
    },
    {
      "type": 1,
      "content": {
        "json": "<div style='margin-top:24px;padding:12px 16px;background:#f3f2f1;border-radius:4px;font-size:12px;color:#605e5c;display:flex;justify-content:center;align-items:center;gap:6px'><a href='https://github.com/Azure/ai-readiness-assessment' style='color:#24292f;text-decoration:none;display:flex;align-items:center;gap:6px'><svg height='16' width='16' viewBox='0 0 16 16' fill='#24292f'><path d='M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z'/></svg>View on GitHub</a></div>"
      },
      "name": "footer"
    }
  ],
